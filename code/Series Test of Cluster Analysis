# ============================================================
# 9. Soft 聚类（用 e1071::cmeans 实现 fuzzy c-means）
# ============================================================
cat("[9] Fuzzy C-means 软聚类...\n")

set.seed(123)
fcm <- cmeans(zscore_mat, centers = k_opt, iter.max = 200, m = 1.25)

# 每个基因最高隶属度
membership_max <- apply(fcm$membership, 1, max)
fcm_cluster <- data.frame(
  Gene = rownames(zscore_mat),
  FCM_Cluster = paste0("Cluster ", fcm$cluster),
  Membership = membership_max
)

# 按隶属度绘制分布（反映聚类质量）
p_membership <- ggplot(fcm_cluster, aes(x = Membership, fill = FCM_Cluster)) +
  geom_histogram(bins = 30, alpha = 0.8, position = "stack") +
  scale_fill_manual(values = cluster_colors, name = "Cluster") +
  geom_vline(xintercept = 0.5, linetype = "dashed", color = "grey40") +
  labs(title = "Fuzzy C-means Membership Score Distribution",
       subtitle = "Higher values indicate stronger cluster membership",
       x = "Maximum Membership Score", y = "Number of Genes") +
  theme_sci

ggsave(file.path(out_dir, "08_fcm_membership.pdf"), p_membership, width = 7, height = 4.5)

# 选高置信度成员（membership > 0.6）绘趋势
fcm_high <- fcm_cluster %>% filter(Membership > 0.6)
cat("  高置信度基因 (membership>0.6):", nrow(fcm_high), "\n\n")

# ============================================================
# 10. 变化轨迹分类（表达模式分类）
# ============================================================
cat("[10] 表达变化轨迹分析...\n")

# 基于F0基线的标准化折变量
pattern_df <- mean_by_tp %>%
  mutate(
    dF15 = F15 - F0,   # 禁食响应
    dR5  = R5  - F0,   # 再喂养早期
    dR47 = R47 - F0,   # 再喂养晚期
    # 分类模式
    pattern = case_when(
      dF15 < -0.5 & dR5 > -0.5 ~ "Fasting-Down\nRefeeding-Recover",
      dF15 > 0.5  & dR5 < 0.5  ~ "Fasting-Up\nRefeeding-Down",
      dF15 < -0.5 & dR5 < -0.5 & dR47 > -0.3 ~ "Late-Recover",
      dF15 > 0.5  & dR5 > 0.5  ~ "Sustained-Up",
      dF15 < -0.5 & dR47 < -0.5 ~ "Sustained-Down",
      abs(dR47 - dF15) > 1 & abs(dF15) < 0.5 ~ "Refeeding-Specific",
      TRUE ~ "Other"
    )
  )

# 统计各模式数量
pattern_count <- pattern_df %>%
  count(pattern) %>%
  arrange(desc(n)) %>%
  mutate(pct = round(n / sum(n) * 100, 1),
         label = paste0(n, "\n(", pct, "%)"))

p_pattern_bar <- ggplot(pattern_count, aes(x = reorder(pattern, n), y = n, fill = pattern)) +
  geom_col(width = 0.7, alpha = 0.9, color = "white") +
  geom_text(aes(label = label), hjust = -0.1, size = 3) +
